    "from sklearn.feature_selection import mutual_info_classif\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# We use a sample because MI is computationally expensive on 595k rows\n",
    "X_sample = X_train_encoded.sample(20000, random_state=42)\n",
    "y_sample = y_train_encoded[X_sample.index]\n",
    "\n",
    "# Calculate MI\n",
    "importances = mutual_info_classif(X_sample, y_sample)\n",
    "mi_series = pd.Series(importances, index=X_train_encoded.columns)\n",
    "\n",
    "# Plotting\n",
    "mi_series.sort_values(ascending=True).plot(kind='barh', figsize=(10, 8), color='teal')\n",
    "plt.title(\"Mutual Information Scores\")\n",
    "plt.xlabel(\"Information Gain\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fe604df3",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.inspection import permutation_importance\n",
    "\n",
    "# Run permutation on the test set to see true generalization\n",
    "perm_result = permutation_importance(\n",
    "    xgb_model, X_test_encoded.sample(5000), y_test_encoded[X_test_encoded.sample(5000).index], \n",
    "    n_repeats=5, random_state=42, n_jobs=-1\n",
    ")\n",
    "\n",
    "# Visualize\n",
    "perm_sorted_idx = perm_result.importances_mean.argsort()\n",
    "plt.figure(figsize=(10, 8))\n",
    "plt.boxplot(perm_result.importances[perm_sorted_idx].T, vert=False, \n",
    "            labels=X_test_encoded.columns[perm_sorted_idx])\n",
    "plt.title(\"Permutation Importance (XGBoost)\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
