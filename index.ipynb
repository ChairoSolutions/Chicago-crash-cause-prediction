    "from sklearn.metrics import accuracy_score, f1_score\n",
    "import pandas as pd\n",
    "\n",
    "evaluation_results = []\n",
    "\n",
    "model_predictions = {\n",
    "    \"Dummy Majority Class\": dummy_pred,\n",
    "    \"Logistic Regression\": y_pred,\n",
    "    \"Random Forest\": rf_pred,\n",
    "    \"XGBoost\": xgb_pred,\n",
    "    \"Tuned Random Forest\": rf_adv_pred\n",
    "}\n",
    "\n",
    "for model_name, preds in model_predictions.items():\n",
    "    evaluation_results.append({\n",
    "        \"Model\": model_name,\n",
    "        \"Accuracy\": accuracy_score(y_test, preds),\n",
    "        \"Macro F1\": f1_score(y_test, preds, average='macro'),\n",
    "        \"Weighted F1\": f1_score(y_test, preds, average='weighted')\n",
    "    })\n",
    "\n",
    "evaluation_df = pd.DataFrame(evaluation_results).round(3)\n",
    "evaluation_df = evaluation_df.sort_values(by=\"Macro F1\", ascending=False)\n",
    "evaluation_df.reset_index(drop=True)"
   ]
