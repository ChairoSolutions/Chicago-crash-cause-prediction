    "from sklearn.inspection import permutation_importance\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# We use the test set to see how it performs on \"unseen\" data\n",
    "result = permutation_importance(\n",
    "    rf, X_test_encoded, y_test, n_repeats=5, random_state=42, n_jobs=-1\n",
    ")\n",
    "\n",
    "# Visualize it\n",
    "sorted_idx = result.importances_mean.argsort()\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.boxplot(result.importances[sorted_idx].T, vert=False, labels=X_test_encoded.columns[sorted_idx])\n",
    "plt.title(\"Permutation Importance (Test Set)\")\n",
    "plt.show()"
   ]
