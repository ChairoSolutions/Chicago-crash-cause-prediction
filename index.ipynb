    "]\n",
    "\n",
    "df_cleaned = df[selected_columns].copy()\n",
    "\n",
    "# Optional: drop rows with missing coordinates (important for Tableau maps)\n",
    "df_cleaned = df_cleaned.dropna(subset=[\"LATITUDE\", \"LONGITUDE\"])\n",
    "\n",
    "# Optional: remove duplicates\n",
    "df_cleaned = df_cleaned.drop_duplicates()\n",
    "\n",
    "# Save reduced dataset\n",
    "df_cleaned.to_csv(\"cleaned_copy.csv\", index=False)\n",
